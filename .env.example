# Copy to .env and fill in. Never commit the real .env.

# Google Gemini (free tier) — used by the LLM that writes the narrative + top actions.
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Google Search Console property.
# Domain property:     sc-domain:baaz.pro
# URL-prefix property: https://baaz.pro/
GSC_SITE_URL=

# GSC auth: a Google service account with Search Console access.
# Add GOOGLE_SERVICE_ACCOUNT_EMAIL as a user in Search Console
# (Settings -> Users and permissions -> Add user -> Restricted).
# Provide EITHER a key-file path OR the two discrete vars below.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Email delivery (Gmail/Workspace: host smtp.gmail.com, port 587,
# SMTP_PASS = a Google App Password, not the account login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_TO=
