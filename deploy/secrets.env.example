# Copy to secrets.env (next to the repo) and fill in — same values as your local .env.
# secrets.env is gitignored; NEVER commit it. Used only to seed Lambda env vars.
GOOGLE_API_KEY=
GSC_SITE_URL=https://baaz.pro/
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# One line, with literal \n escapes (exactly as in your .env). The app un-escapes them.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
REPORT_TO=
